{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "billowing-forest-1bf7",
  "compatibility_date": "2026-07-10",
  "assets": {
    "directory": "./",
    "not_found_handling": "404-page"
  },
  // Add this for the NOAA proxy worker
  "workers": [
    {
      "name": "noaa-proxy",
      "main": "noaa-proxy-minified.js",
      "route": "api.macachor.com/*"
    }
  ]
